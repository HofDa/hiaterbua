    type: z.enum([
      'water',
      'rest',
      'move',
      'disturbance',
      'note',
      'start',
      'pause',
      'resume',
      'stop',
    ]),
    lat: nullableNumber.optional(),
    lon: nullableNumber.optional(),
    comment: optionalTrimmedString,
