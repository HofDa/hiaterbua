  currentEnclosureName,
  activeAssignment,
  effectiveHerdCount,
  endingAssignmentId,
  selectedEnclosureId,
  availableEnclosures,
  assignmentCount,
  assignmentNotes,
  assignmentError,
  assignmentSaving,
  recentAssignments,
  enclosuresById,
  onSelectedEnclosureIdChange,
  onAssignmentCountChange,
  onAssignmentNotesChange,
  onSubmit,
  onEndAssignment,
