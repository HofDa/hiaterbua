    setSelectedEditTrackpointIndex,
    setIsAddingEditTrackpoint,
    setActionError,
    setIsSaving,
    setExpandedHistoryDays,
    setExpandedHistorySessionId,
  })

  return {
    ...sessionController,
    ...historyEditController,
  }
